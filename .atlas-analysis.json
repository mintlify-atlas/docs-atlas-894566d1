  "keyFeatures": [
    "Verifiable agent identity with DID-based authentication",
    "Signed delegation chains with RFC 9421 HTTP signatures",
    "Local gateway for request signing and approved-claim enforcement",
    "Multi-language SDKs (TypeScript, Python, Go)",
    "OpenClaw integration for AI agent workflows",
    "MCP (Model Context Protocol) support with tool filtering",
    "Managed, enterprise, and open-source deployment modes"
  ],
  "publicApiSurface": [
    "GET /v1/namespaces/claims - List approved service authorizations",
    "POST /v1/claims - Submit authorization request",
    "PATCH /v1/claims/:id - Update authorization status",
    "GET /v1/verify - Verify agent authorization",
    "GET /.well-known/did.json - Resolve DID document",
    "sigilum gateway start - Start local gateway",
    "sigilum gateway connect - Pair gateway with dashboard",
    "sigilum openclaw connect - One-command OpenClaw onboarding",
    "@sigilum/sdk (TypeScript SDK)",
    "sigilum (Python SDK)",
    "sigilum.local/sdk-go (Go SDK)"
  ]
